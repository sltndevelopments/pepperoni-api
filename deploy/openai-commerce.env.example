# Copy to VPS as /var/www/pepperoni/openai-commerce.env (chmod 600). Never commit secrets.
# Used by scripts/upload-openai-feed-sftp.sh (called from sync-vps.sh every 10 min).
# Spec: https://developers.openai.com/commerce/specs/file-upload/overview

OPENAI_COMMERCE_SFTP_HOST=
OPENAI_COMMERCE_SFTP_USER=
OPENAI_COMMERCE_SFTP_REMOTE_PATH=/incoming/openai-commerce-kazan-delicacies.tsv.gz
OPENAI_COMMERCE_SFTP_IDENTITY=/root/.ssh/openai_commerce_ed25519
OPENAI_COMMERCE_SFTP_PORT=22

# Optional overrides:
# OPENAI_COMMERCE_LOCAL_FEED=/var/www/pepperoni/repo/public/openai-commerce-kazan-delicacies.tsv.gz
# OPENAI_COMMERCE_STABLE_NAME=openai-commerce-kazan-delicacies.tsv.gz
