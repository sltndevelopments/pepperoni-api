# Add these to /var/www/pepperoni/seo-agent.env on production.
# Do not commit real credentials.
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
AVITO_USER_ID=
AVITO_POLL_INTERVAL=10
AVITO_CHATS_PAGE_SIZE=100
AVITO_CHATS_MAX_PAGES=5
AVITO_RECRUITMENT_URL_MARKERS=vakansii
AVITO_WORKER_DB=/var/www/pepperoni/data/avito-worker.sqlite3
AVITO_CATALOG_URL=https://api.pepperoni.tatar/api/products
AVITO_CATALOG_CACHE_SECONDS=600

# Preferred provider for Avito replies: OpenAI GPT-4.1 mini.
# OPENAI_API_KEY=
#
# Advanced override for any OpenAI-compatible provider:
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4.1-mini
#
# The worker falls back to existing DEEPSEEK_* variables only while OpenAI is unset.
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-v4-flash

# Existing Pepperoni lead pipeline settings:
LEADS_BOT_TOKEN=
LEADS_GROUP_ID=
