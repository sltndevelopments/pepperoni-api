# /etc/logrotate.d/nginx-ai-bots
# Daily rotation of the AI-bot access log on api.pepperoni.tatar VPS.

/var/log/nginx/ai-bots.log {
    daily
    rotate 90
    missingok
    compress
    delaycompress
    notifempty
    create 0640 www-data adm
    sharedscripts
    postrotate
        if [ -f /run/nginx.pid ]; then
            kill -USR1 $(cat /run/nginx.pid)
        fi
    endscript
}
