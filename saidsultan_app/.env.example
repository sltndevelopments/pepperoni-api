# Копируйте в .env и заполните. .env не коммитить!
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...
# DEEPSEEK_API_KEY=sk-...      (движок Scanner + Advisor)
# TELEGRAM_BOT_TOKEN=...       (токен от @BotFather для бота)
# OPENAI_API_KEY=sk-...        (опционально, если вернётесь на OpenAI)
# SKIP_CF_CHECK=1              (только для локальной разработки — отключает проверку Cloudflare)
# SMTP (для отправки отчётов на email)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=app_password
