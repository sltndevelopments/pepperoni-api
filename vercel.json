{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://googletagmanager.com https://mc.yandex.ru https://mc.yandex.com https://yastatic.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://mc.yandex.ru https://mc.yandex.com https://yandex.ru; frame-src https://www.googletagmanager.com;" }
      ]
    },
    {
      "source": "/products/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/en/products/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ],
  "redirects": [
    { "source": "/pepperoni-dlya-azs", "destination": "/dlya-azs", "permanent": true },
    { "source": "/pepperoni-private-label", "destination": "/kontraktnoe-proizvodstvo", "permanent": true },
    { "source": "/pepperoni-dlya-pekaren", "destination": "/dlya-pekaren", "permanent": true },
    { "source": "/pepperoni-dlya-setey", "destination": "/dlya-setey", "permanent": true },
    { "source": "/pepperoni-dlya-horeca", "destination": "/dlya-horeca", "permanent": true },
    { "source": "/pepperoni-dlya-distribyutorov", "destination": "/dlya-distributorov", "permanent": true }
  ]
}
