node_modules/
scripts/gsc-key.json
*.pem
*-key.json

# OS / IDE
.DS_Store
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.idea/
.vscode/
*.swp

# Local env (never commit)
.env
.env.*
!.env.example

# Google OAuth / YouTube client secrets (never commit)
client_secret*.json
**/youtube-oauth*.json
**/google-oauth*.json

# SEO Agent runtime data (SQLite DB + logs)
data/seo_data.db
data/*.db-wal
data/*.db-shm
data/logs/
!data/logs/.gitkeep
!data/.gitkeep

# Python bytecode caches (never commit)
__pycache__/
*.pyc

# QA quarantine — broken pages held back by qa_pages.py, regenerated each run
data/quarantine/
# Runtime watermark for quarantine growth checks (must survive VPS git reset)
data/quarantine_baseline.json
data/quarantine_baseline.json.tmp
# Proxy lock + transient runtime artifacts
data/llm_costs.json.lock

# Sales intel: keep README, scripts, reports, small guides — not raw scrapes / big spreadsheets
sales-intel/raw/
sales-intel/data/*.csv
sales-intel/data/*.xlsx

# Sales agent runtime (isolated from public/ site)
sales-agent/data/*
!sales-agent/data/.gitkeep
!sales-agent/data/sales_memory.json
sales-agent/data/sales_tg_authorized.json
sales-agent/data/sales_tg_pending.json
sales-agent/data/email_send_log.jsonl
sales-agent/data/email_blacklist.json
sales-agent/.env
sales-agent/secrets/
!sales-agent/secrets/.gitkeep
# Toolsmith-generated tools (Steve writes these autonomously at runtime,
# tracked via data/steve_tools.json, not by a human) — keep untracked.
sales-agent/agents/*.py
!sales-agent/agents/__init__.py
.vercel

# Ops snapshots (DNS exports, secret indexes, etc.) — never commit
ops/backups/*
!ops/backups/README.md
data/gsc_submitted.json
data/tg_authorized.json
data/tg_notify.json
data/tg_pending.json
data/brain_journal.jsonl
data/.deploy_stamp
data/tmp/
